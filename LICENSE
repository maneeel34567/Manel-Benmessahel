import { useState } from "react";
import { BrowserRouter as Router, Routes, Route, useParams, useNavigate } from "react-router-dom";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Play, Search, ArrowLeft } from "lucide-react";
import { motion } from "framer-motion";

const animeData = [
  {
    id: "crimson-lotus",
    title: "Crimson Lotus",
    genre: "Action / Fantasy",
    episodes: [
      { id: "1", title: "Episode 1 - Awakening", url: "https://www.youtube.com/embed/dQw4w9WgXcQ" },
      { id: "2", title: "Episode 2 - The Blade", url: "https://www.youtube.com/embed/dQw4w9WgXcQ" }
    ]
  },
  {
    id: "moonlight-blade",
    title: "Moonlight Blade",
    genre: "Adventure",
    episodes: [
      { id: "1", title: "Episode 1 - Journey Begins", url: "https://www.youtube.com/embed/dQw4w9WgXcQ" }
    ]
  },
  {
    id: "cherry-blossom-days",
    title: "Cherry Blossom Days",
    genre: "Slice of Life",
    episodes: [
      { id: "1", title: "Episode 1 - Spring Morning", url: "https://www.youtube.com/embed/dQw4w9WgXcQ" }
    ]
  },
  {
    id: "neon-samurai",
    title: "Neon Samurai",
    genre: "Sci-Fi / Cyberpunk",
    episodes: [
      { id: "1", title: "Episode 1 - Neon City", url: "https://www.youtube.com/embed/dQw4w9WgXcQ" }
    ]
  }
];

const bgStyle = {
  background: "radial-gradient(circle at top, #ff4da6 0%, #0a0a0a 40%, #000 100%)"
};

function Home() {
  const [query, setQuery] = useState("");
  const navigate = useNavigate();

  const filtered = animeData.filter((a) =>
    a.title.toLowerCase().includes(query.toLowerCase())
  );

  return (
    <div className="min-h-screen text-white" style={bgStyle}>
      {/* Header */}
      <header className="flex items-center justify-between p-6 backdrop-blur bg-black/40 border-b border-pink-500/30">
        <div className="flex items-center gap-3">
          <img
            src="/mnt/data/file_0000000050fc71f59b28d1b0811d8cd7"
            alt="Sakura Stream Logo"
            className="w-10 h-10 rounded-full shadow-lg shadow-pink-500/40"
          />
          <h1 className="text-2xl font-bold text-pink-400 tracking-wide drop-shadow-lg">
            Sakura Stream
          </h1>
        </div>
        <Button className="rounded-2xl bg-pink-500 hover:bg-pink-600 text-white shadow-lg shadow-pink-500/40">
          Sign In
        </Button>
      </header>

      {/* Hero */}
      <section className="text-center py-16 px-4">
        <h2 className="text-5xl font-extrabold mb-4 text-pink-300 drop-shadow-lg">
          Watch Anime in Sakura Glow 🌸
        </h2>
        <p className="text-pink-100/70 mb-6">
          Stream anime in a neon sakura world.
        </p>

        <div className="flex items-center justify-center gap-2 max-w-md mx-auto">
          <Input
            placeholder="Search anime..."
            value={query}
            onChange={(e) => setQuery(e.target.value)}
            className="bg-black/40 border-pink-500/40 text-white"
          />
          <Button className="rounded-xl bg-pink-500 hover:bg-pink-600">
            <Search size={18} />
          </Button>
        </div>
      </section>

      {/* Anime Grid */}
      <section className="px-6 pb-16">
        <h3 className="text-xl font-semibold mb-4 text-pink-300">
          Featured Anime
        </h3>

        <div className="grid md:grid-cols-4 gap-4">
          {filtered.map((anime) => (
            <motion.div
              key={anime.id}
              whileHover={{ scale: 1.07 }}
              onClick={() => navigate(`/anime/${anime.id}/1`)}
              className="cursor-pointer"
            >
              <Card className="rounded-2xl overflow-hidden bg-black/40 border border-pink-500/30 shadow-lg shadow-pink-500/20">
                <CardContent className="p-4">
                  <div className="h-32 bg-gradient-to-br from-pink-500/40 to-black rounded-xl mb-3 flex items-center justify-center">
                    <Play className="text-pink-300" />
                  </div>
                  <h4 className="font-bold text-pink-200">{anime.title}</h4>
                  <p className="text-sm text-pink-100/60">{anime.genre}</p>
                </CardContent>
              </Card>
            </motion.div>
          ))}
        </div>
      </section>
    </div>
  );
}

function AnimePage() {
  const { id, episode } = useParams();
  const navigate = useNavigate();

  const anime = animeData.find((a) => a.id === id);

  if (!anime) return <div className="p-6 text-white">Anime not found</div>;

  const currentEpisode = anime.episodes.find((e) => e.id === episode) || anime.episodes[0];

  return (
    <div className="min-h-screen text-white p-6" style={bgStyle}>
      <Button
        className="mb-4 rounded-xl bg-pink-500 hover:bg-pink-600"
        onClick={() => navigate("/")}
      >
        <ArrowLeft className="mr-2" /> Back
      </Button>

      <h1 className="text-3xl font-bold text-pink-300 mb-2 drop-shadow">
        {anime.title}
      </h1>
      <p className="text-pink-100/70 mb-6">{anime.genre}</p>

      <div className="aspect-video w-full mb-6 bg-black/60 rounded-xl overflow-hidden border border-pink-500/30 shadow-lg shadow-pink-500/20">
        <iframe
          className="w-full h-full"
          src={currentEpisode.url}
          title="Anime Episode"
          allowFullScreen
        />
      </div>

      <h2 className="text-xl font-semibold mb-3 text-pink-300">Episodes</h2>

      <div className="grid gap-2">
        {anime.episodes.map((ep) => (
          <div
            key={ep.id}
            onClick={() => navigate(`/anime/${anime.id}/${ep.id}`)}
            className="p-3 bg-black/40 border border-pink-500/20 rounded-xl cursor-pointer hover:bg-pink-500/20"
          >
            {ep.title}
          </div>
        ))}
      </div>
    </div>
  );
}

export default function SakuraStream() {
  return (
    <Router>
      <Routes>
        <Route path="/" element={<Home />} />
        <Route path="/anime/:id/:episode" element={<AnimePage />} />
      </Routes>
    </Router>
  );
}
